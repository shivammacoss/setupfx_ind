# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB (optimized for 3000+ users with connection pooling)
MONGODB_URI=mongodb://localhost:27017/stockpip

# Redis (optional - for scaling to 3000+ users)
# Install Redis: brew install redis (Mac) or apt install redis-server (Linux)
# Start Redis: redis-server
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=your-strong-secret-key-here
JWT_EXPIRES_IN=7d

# SMTP (Hostinger / Nodemailer) — signup email OTP + forgot password
# Hostinger: smtp.hostinger.com
# — Port 465: SMTP_SECURE=true (implicit SSL)
# — Port 587: SMTP_SECURE=false (STARTTLS) — wrong secure flag is the #1 connection failure
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-mailbox-password
# Debug SMTP in server logs: SMTP_DEBUG=true
# Optional: override From (defaults to SMTP_USER)
# SMTP_FROM=you@yourdomain.com
# SMTP_FROM_NAME=SetupFX
# Set to false to disable signup OTP even when SMTP is set (not recommended prod)
# REQUIRE_SIGNUP_OTP=true

# CORS — comma-separated browser origins (no trailing slashes). Local dev ports are always allowed in code.
# Local: CORS_ORIGIN=http://localhost:5173
# Production: CORS_ORIGIN=https://setupfx.io,https://www.setupfx.io,https://admin.setupfx.io
CORS_ORIGIN=http://localhost:5173
# Optional: base URL for Zerodha OAuth redirects (/admin/zerodha). Defaults to admin.* origin or first CORS origin.
# FRONTEND_URL=https://admin.setupfx.io

# Admin
ADMIN_DEFAULT_PASSWORD=change-this-admin-password

# Demo Mode (set to 'false' in production to disable auto-creation of funded accounts)
DEMO_MODE_ENABLED=true

# Guest User Default Password (for demo mode)
GUEST_DEFAULT_PASSWORD=change-this-password
GUEST_DEFAULT_BALANCE=10000

# MetaAPI Configuration (server-side proxy - keeps token secure)
METAAPI_ACCOUNT_ID=your-metaapi-account-id
METAAPI_AUTH_TOKEN=your-metaapi-auth-token
METAAPI_BASE_URL=https://mt-client-api-v1.new-york.agiliumtrade.ai
METAAPI_MARKET_DATA_URL=https://mt-market-data-client-api-v1.london.agiliumtrade.ai
# Optional: {"XAUUSD":["GOLD","XAUUSD.i"]} — extra MT symbol names for historical charts
# METAAPI_CHART_SYMBOL_ALIASES=
